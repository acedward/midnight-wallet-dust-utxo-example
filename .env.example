# Copy to .env before `docker compose up`. These are the values the published
# benchmark results were produced with.

# Host port mappings (change if they clash with another local midnight stack)
NODE_PORT=29944
INDEXER_PORT=28088
PROOF_PORT=26300
API_PORT=3300

# Throughput configuration
TX_CONCURRENCY=32        # parallel tx pipelines in the api (keep <= TARGET_UTXOS)
TARGET_UTXOS=110         # benchmark wallet NIGHT UTXOs = dust coins = max burst size
EXTERNAL_UTXOS=100       # external wallet UTXO pool (>= largest wave/burst)
AMOUNT_PER_UTXO=2000000000000   # NIGHT per benchmark UTXO — drives dust generation rate

# Fee tuning (defaults are fine; kept for experiments)
#FEE_BLOCKS_MARGIN=5
#FEE_OVERHEAD=300000000000000
